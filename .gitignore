# Big binaries: kept LOCAL, not in git (reproducible or backed up separately)
# - DB (507MB) rebuildable from scripts + batch_outputs + source
# - 1_source_data (433MB) original Data Axle source; back up separately
2_database/*.db
1_source_data/

# Transient
5_working/inputs/_night_batch.json
# Kimi Allegro app loop staging: paste files + raw swarm returns (local, transient, possibly large)
5_working/kimi_returns/

# System / session
.DS_Store
**/.DS_Store
.firecrawl/
.remember/

# NOTE: 5_working/batch_outputs/ IS committed (~8MB) as raw enrichment provenance.

# BrightWave raw source DOWNLOADS — keep local (may be large / paywalled), like the DB & Data Axle source.
# Ignore the contents of every brief's sources/ folder, but keep the empty folder in git via .gitkeep.
# (Briefs and BrightWave results/ stay committed.)
7_research_requests/*/sources/*
!7_research_requests/*/sources/.gitkeep
